# Steam app IDs and display names to track.
# Format: app_id:Display Name,app_id:Display Name
STEAM_GAMES=2483190:Example Game

# Alternative format:
# STEAM_APP_IDS=2483190
# GAME_NAME_2483190=Example Game

# Local JSON file that stores the last seen update per app.
STATE_FILE=.game_changelog_state.json

# Number of recent Steam news/changelog entries to inspect per game.
NEWS_COUNT=10

# First run initializes state without alerting, to avoid old-update spam.
ALERT_ON_FIRST_RUN=false

# Keep this false to ignore external media/news posts and track official update posts only.
INCLUDE_EXTERNAL_NEWS=false

# Optional Discord webhook for alerts. If unset, alerts print to stdout only.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Network timeout for Steam and Discord requests.
REQUEST_TIMEOUT_SECONDS=20
